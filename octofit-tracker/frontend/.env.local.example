# Required when running the frontend in a GitHub Codespace.
# Copy this file to .env.local and fill in your Codespace name.
#
# Your Codespace name appears in the URL when you open the Codespace, e.g.:
#   https://my-repo-abc123-8000.app.github.dev  →  VITE_CODESPACE_NAME=my-repo-abc123
#
# Without this variable the frontend falls back to http://localhost:8000

VITE_CODESPACE_NAME=
